# Python
.venv/
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/

# Testing / tooling
.pytest_cache/
.ruff_cache/
.pyright/
.mypy_cache/
htmlcov/
.coverage
coverage.xml

# Private local runtime config, secrets, tokens, and the project seed.
# Rule: anything named "local" or holding real secrets is NEVER committed —
# commit a *.example.* skeleton instead (skeletons are re-included below).
.env
.env.*
*.local
*.local.*
!*.example
!*.example.*
# Explicit sensitive files that are not named "local":
configs/scanner/providers.yaml
data/seeds/master_seed.txt

# Local biodiversity data, media manifests, reports, and generated outputs (preserve .gitkeep)
data/raw/*
data/interim/*
data/processed/*
data/manifests/*
data/reports/*
data/splits/*
data/media/*
data/db/*
data/images/*
data/external/*
data/annotated_dataset/
data/cache/*
data/profiles/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/manifests/.gitkeep
!data/reports/.gitkeep
!data/splits/.gitkeep
!data/media/.gitkeep
!data/db/.gitkeep
!data/images/.gitkeep
!data/external/.gitkeep
!data/cache/.gitkeep
!data/profiles/.gitkeep

# Taxonomy layer: generated audit/candidate/lexicon outputs and the local override
# copy are NOT committed; the example override template and .gitkeep are.
data/taxonomy/*
!data/taxonomy/.gitkeep
!data/taxonomy/manual_overrides.example.toml

# Local databases (SQLite observation log)
*.sqlite3
*.sqlite
*.db

# Model artefacts generated by training/export workflows
models/checkpoints/*
models/exports/*
models/quantized/*
!models/checkpoints/.gitkeep
!models/exports/.gitkeep
!models/quantized/.gitkeep

# Large binary / generated files
*.pt
*.pth
*.onnx
*.ckpt
*.duckdb
*.parquet
*.log
logs/

# Dataset archives (Big Bird etc.) — but keep the tiny test fixture
*.zip
!tests/fixtures/tiny_bigbird.zip

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp

# Jupyter checkpoints
.ipynb_checkpoints/
venv/
*.pyc
.pio/
node_modules/
*.gcode
.DS_Store
*.aux
*.fls
*.fdb_latexmk
*.synctex.gz
*.log
.cache/
