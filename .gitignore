# Python
.venv/
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/

# Testing / tooling
.pytest_cache/
.ruff_cache/
.pyright/
.mypy_cache/
htmlcov/
.coverage
coverage.xml

# Private local runtime config
.env

# Local biodiversity data, media manifests, reports, and generated outputs (preserve .gitkeep)
data/raw/*
data/interim/*
data/processed/*
data/manifests/*
data/reports/*
data/splits/*
data/media/*
data/db/*
data/images/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/manifests/.gitkeep
!data/reports/.gitkeep
!data/splits/.gitkeep
!data/media/.gitkeep
!data/db/.gitkeep
!data/images/.gitkeep

# Local databases (SQLite observation log)
*.sqlite3
*.sqlite
*.db

# Model artefacts generated by training/export workflows
models/checkpoints/*
models/exports/*
models/quantized/*
!models/checkpoints/.gitkeep
!models/exports/.gitkeep
!models/quantized/.gitkeep

# Large binary / generated files
*.pt
*.pth
*.onnx
*.duckdb
*.parquet
*.log
logs/

# IDE
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp

# Jupyter checkpoints
.ipynb_checkpoints/
venv/
*.pyc
.pio/
node_modules/
*.gcode
.DS_Store
*.aux
*.fls
*.fdb_latexmk
*.synctex.gz
*.log
.cache/
