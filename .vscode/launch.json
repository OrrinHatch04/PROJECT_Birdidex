{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python"
    },
    {
      "name": "Bird ROI Scanner: Help",
      "type": "debugpy",
      "request": "launch",
      "module": "bird_roi_scan.cli",
      "args": ["--help"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python"
    },
    {
      "name": "Dataset: Score Species",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/dataset/04_score_species.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python"
    },
    {
      "name": "Cyberdeck UI: Dev Server",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["bird_ui.server:app", "--reload", "--host", "127.0.0.1", "--port", "8000"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python"
    }
  ]
}
