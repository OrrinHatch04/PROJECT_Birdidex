{
  "name": "BIRDIDEX uv",
  "dockerComposeFile": "../compose.yaml",
  "service": "birdidex-jupyter",
  "workspaceFolder": "/workspace/birdidex",
  "overrideCommand": false,
  "forwardPorts": [8888, 8000],
  "postCreateCommand": "uv sync --all-groups --frozen && uv run python -m ipykernel install --user --name birdidex-uv --display-name 'BIRDIDEX uv (.venv)'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/birdidex/.venv/bin/python",
        "jupyter.notebookFileRoot": "${workspaceFolder}"
      }
    }
  }
}
