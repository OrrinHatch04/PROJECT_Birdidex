# Copy this file to .env and fill in real values. Never commit .env.

# eBird API key (required for ebird provider)
EBIRD_API_KEY=your_ebird_api_key_here

# Generic search API key (for web_search provider - fill in when you choose a provider)
SEARCH_API_KEY=

# Optional: override default config paths
# BIRDIDEX_ROI_CONFIG=configs/roi/roi.yaml
# BIRDIDEX_PROVIDERS_CONFIG=configs/scanner/providers.yaml
