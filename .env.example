# Copy this file to .env.local and fill in local values. NEVER commit .env.local / .env.
# BIRDIDEX reads these from the environment first, then from .env.local, then .env.

# eBird API token — https://ebird.org/api/keygen (sent as the X-eBirdApiToken header).
# Required for `providers dry-run --provider ebird` and eBird priors in the pipeline.
EBIRD_API_KEY=

# iNaturalist OAuth access token (optional). Public photo/observation endpoints work
# without it; set it only if you hit an endpoint that needs auth.
INATURALIST_ACCESS_TOKEN=

# Deterministic project master seed. Source of truth is the gitignored
# data/seeds/master_seed.txt; set this to override it explicitly.
BIRDIDEX_MASTER_SEED=

# Optional path overrides (defaults shown).
# BIRDIDEX_CLASS_INDEX_PATH=data/processed/birddex/class_index.json
# BIRDIDEX_ROI_CONFIG=configs/roi/roi.yaml
# BIRDIDEX_PROVIDERS_CONFIG=configs/scanner/providers.yaml
