# Copy this file to .env and fill in local runtime values. Never commit .env.

# Optional eBird provider token, read only from local runtime config.
EBIRD_API_KEY=

# Optional documented search provider token. Do not scrape search result pages directly.
SEARCH_API_KEY=

# Optional: override default config paths
# BIRDIDEX_ROI_CONFIG=configs/roi/roi.yaml
# BIRDIDEX_PROVIDERS_CONFIG=configs/scanner/providers.yaml
